# Backend OpenAI / LLM settings
# Copy these names into the real backend .env when running the project.

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_TIMEOUT_SECONDS=30

# Related backend settings used by the same app runtime
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/nextstep
AUTH_SECRET=change-this-in-development

# Frontend settings for calling the backend API
VITE_API_BASE_URL=http://127.0.0.1:8000/api
VITE_USE_MOCK=false
